{
  "name": "diffguard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "bun": ">=1.2.0"
  },
  "bin": {
    "diffguard": "./dist/cli.js"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "cli": "PATH=\"$HOME/.bun/bin:$PATH\" bun run src/cli.ts",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "test": "bunx vitest run --coverage",
    "test:watch": "bunx vitest",
    "test:coverage": "bunx vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "ts-morph": "^27.0.2",
    "zod": "^4.3.6"
  }
}
