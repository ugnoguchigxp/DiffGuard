# Enable LLM review without --enable-llm flag
DIFFGUARD_ENABLE_LLM=false

# LLM mode:
# - gemma-command     : execute local command (default: gemma4)
# - local-openai-api  : call OpenAI-compatible local API (for ../localLlm)
DIFFGUARD_LLM_MODE=gemma-command

# gemma-command mode
# - Use `gemma4` for Gemma 4 (default)
# - Use `bonsai` for Bonsai backend
DIFFGUARD_LLM_COMMAND=gemma4
DIFFGUARD_LLM_TIMEOUT_MS=5000
# Optional: keep/restore chat sessions via localLlm CLI
# DIFFGUARD_LLM_SESSION_DIR=/absolute/path/to/sessions
# DIFFGUARD_LLM_NO_SESSION=false

# local-openai-api mode (optional for ../localLlm)
DIFFGUARD_LOCAL_LLM_API_BASE_URL=http://127.0.0.1:44448/v1
DIFFGUARD_LOCAL_LLM_MODEL=gemma-4-e4b-it
DIFFGUARD_LOCAL_LLM_MAX_TOKENS=256
DIFFGUARD_LOCAL_LLM_TEMPERATURE=0
